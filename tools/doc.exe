#!/usr/bin/env bash
set -euo pipefail

# Wrapper simples apontando para o pipeline bytes_family.
# Usos:
#   tools/doc.exe --pdf arquivo.pdf --tag despacho [--registry io/catalog_official/catalog_registry.json] [--ai-model BAAI/bge-reranker-v2-m3]
#   tools/doc.exe --dir catalog_dir_source --tag despacho [--registry io/catalog_official/catalog_registry.json] [--ai-model BAAI/bge-reranker-v2-m3]
#
# Observação:
# - catálogo sempre usa page_index=0;
# - inferência usa TAG já catalogada e compara páginas do PDF contra referência de capa.
# - IA lexical roda somente em GPU CUDA (sem fallback CPU).

PDF=""
DIR=""
TAG=""
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
REGISTRY="$ROOT/io/catalog_official/catalog_registry.json"
AI_MODEL="BAAI/bge-reranker-v2-m3"
AI_BATCH_SIZE="16"
AI_MAX_EXAMPLES="4"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pdf) PDF="$2"; shift 2;;
    --dir) DIR="$2"; shift 2;;
    --tag) TAG="$2"; shift 2;;
    --registry) REGISTRY="$2"; shift 2;;
    --ai-model) AI_MODEL="$2"; shift 2;;
    --ai-batch-size) AI_BATCH_SIZE="$2"; shift 2;;
    --ai-max-examples) AI_MAX_EXAMPLES="$2"; shift 2;;
    *) echo "uso: tools/doc.exe (--pdf arquivo.pdf | --dir /pasta) --tag TAG [--registry catalog_registry.json] [--ai-model MODEL] [--ai-batch-size N] [--ai-max-examples N]"; exit 1;;
  esac
done

if [[ -z "$TAG" || ( -z "$PDF" && -z "$DIR" ) ]]; then
  echo "uso: tools/doc.exe (--pdf arquivo.pdf | --dir /pasta) --tag TAG [--registry catalog_registry.json] [--ai-model MODEL] [--ai-batch-size N] [--ai-max-examples N]"
  exit 1
fi

if [[ -n "$DIR" ]]; then
  PYTHONPATH=src:. python -m pdfcatch.family.similarity_search \
    --dir "$DIR" --tag "$TAG" --registry "$REGISTRY" \
    --ai-model "$AI_MODEL" --ai-batch-size "$AI_BATCH_SIZE" --ai-max-examples "$AI_MAX_EXAMPLES"
else
  PYTHONPATH=src:. python -m pdfcatch.family.similarity_search \
    --pdf "$PDF" --tag "$TAG" --registry "$REGISTRY" \
    --ai-model "$AI_MODEL" --ai-batch-size "$AI_BATCH_SIZE" --ai-max-examples "$AI_MAX_EXAMPLES"
fi
