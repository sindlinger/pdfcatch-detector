#!/usr/bin/env bash
set -euo pipefail

# Check rápido de sintaxe/imports dos módulos Python.
# Uso:
#   tools/verificar_sintaxe.exe
#   tools/verificar_sintaxe.exe src/pdfcatch/family

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TARGET="${1:-src/pdfcatch/family}"

cd "$ROOT"
PYTHONPATH=src:. python -m compileall "$TARGET"
echo "verificacao_sintaxe: ok ($TARGET)"
