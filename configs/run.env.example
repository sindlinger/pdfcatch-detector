# pdfcatch batch config (copy to configs/run.env)
#
# Rodar:
#   cd /mnt/c/git/pdfcatch-detector
#   cli doc -d :Q1-10 --save-files Output
#
# (Opcional) se voce costuma rodar scripts de fora do repo e quer manter import resolvendo:
#   PYTHONPATH=src

# Optional: for shells that `source` this file before running python.
PYTHONPATH=src

# Optional: default candidate PDF for the TUI (so you can run `python tools/tui.py` without args)
# PDFCATCH_CANDIDATE_PDF=/mnt/c/Users/pichau/Desktop/geral_pdf/quarentena/2020167511.pdf

# Where to scan PDFs (relative paths are resolved from repo root)
PDFCATCH_PDF_DIR=:Q

# Optional: directory aliases for shorthand in PDFCATCH_PDF_DIR.
# Example:
#   PDFCATCH_ALIAS_Q=/mnt/c/Users/pichau/Desktop/geral_pdf/quarentena
#   PDFCATCH_PDF_DIR=:Q10-40   # 1-based range (inclusive) over sorted PDFs in that folder
# Alias keys are single letters: :Q, :D, etc.
PDFCATCH_ALIAS_Q=/mnt/c/Users/pichau/Desktop/geral_pdf/quarentena

# If 1, scan subdirectories too
PDFCATCH_RECURSIVE=0

# How many PDFs to process from the folder (0 = all)
PDFCATCH_LIMIT=0

# Templates JSON file (relative paths are resolved from repo root)
PDFCATCH_TEMPLATES_JSON=configs/templates.json

# Output directory (relative paths are resolved from repo root)
PDFCATCH_OUTPUT_DIR=Output

# Engine options
PDFCATCH_TOP_K=3
# Regra de elegibilidade do metodo bytes (K=2):
# - nenhuma pagina abaixo de MIN_ANY
# - pagina 1 precisa ser > MIN_P1
# - pagina 2 precisa ser >= MIN_P2
PDFCATCH_BYTES_MIN_ANY=0.40
PDFCATCH_BYTES_MIN_P1=0.60
PDFCATCH_BYTES_MIN_P2=0.40
PDFCATCH_ENABLE_STREAM=1
PDFCATCH_ENABLE_TEXT=1
PDFCATCH_ENABLE_IMAGE=1
PDFCATCH_IMAGE_DPI=72
PDFCATCH_IMAGE_HASH_SIZE=8
PDFCATCH_STREAM_PREFILTER_MIN=0.45

# Classification threshold (0..1). If best score < MIN_FINAL => treated as UNKNOWN in summary.
PDFCATCH_MIN_FINAL=0.60
